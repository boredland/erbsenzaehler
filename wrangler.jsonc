{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "erbsenzaehler",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "erbsenzaehler-db",
      "database_id": "bbf2dbb9-86c0-46ac-b6d0-645c2dbc4792"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PHOTOS",
      "bucket_name": "erbsenzaehler-photos"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
