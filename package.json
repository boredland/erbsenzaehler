{
  "name": "gartenapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create gartenapp-db",
    "db:migrate": "wrangler d1 execute gartenapp-db --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute gartenapp-db --remote --file=./schema.sql",
    "r2:create": "wrangler r2 bucket create gartenapp-photos"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.5.2",
    "wrangler": "^3.78.0"
  }
}
